# Required in production (32+ characters)
ADMIN_AUTH_SECRET=replace_with_a_long_random_secret_value

# Required for database-backed persistence (Neon Postgres URL)
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# Required on Vercel when using Blob uploads
# https://vercel.com/docs/storage/vercel-blob
# BLOB_READ_WRITE_TOKEN=<vercel_blob_token>

# Admin username
ADMIN_USERNAME=admin

# Recommended secure mode: set both hash and salt generated from your password
# Generate with: npm run admin:hash -- "your-password"
# ADMIN_PASSWORD_HASH=<hex string>
# ADMIN_PASSWORD_SALT=<random salt>

# Optional fallback for local development only (not recommended for production)
# ADMIN_PASSWORD=change-me

RESEND_API_KEY=replace_with_your_resend_api_key
